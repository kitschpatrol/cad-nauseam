{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cad-nauseam",
	"compatibility_date": "2026-04-22",
	"dev": {
		"local_protocol": "https",
		"port": 8787,
	},
	"assets": {
		"directory": "./site",
		"html_handling": "drop-trailing-slash",
	},
	"preview_urls": false,
	"routes": ["frontiernerds.com/cad-nauseam*"],
	"observability": {
		"enabled": true,
	},
}
