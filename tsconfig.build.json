{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"target": "es2021",
		"rootDir": "src",
		"allowImportingTsExtensions": false,
		"allowJs": false,
		"checkJs": false,
		"declaration": true,
		"declarationMap": true,
		"emitDeclarationOnly": true,
		"noEmit": false,
		"outDir": "dist"
	},
	"include": ["src/**/*.ts"],
	"exclude": ["src/**/*.test.ts", "test/**/*", "dist/**/*"]
}
