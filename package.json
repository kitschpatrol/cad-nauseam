{
	"name": "cad-nauseam",
	"version": "1.0.0",
	"private": true,
	"description": "A web-based implementation of Wolfram's one-dimensional cellular automata.",
	"keywords": [
		"wolfram",
		"cellular-automata"
	],
	"homepage": "https://frontiernerds.com/cad-nauseam",
	"bugs": "https://github.com/kitschpatrol/cad-nauseam/issues",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/kitschpatrol/cad-nauseam.git"
	},
	"license": "MIT",
	"author": {
		"name": "Eric Mika",
		"email": "eric@ericmika.com",
		"url": "https://ericmika.com"
	},
	"sideEffects": [
		"./dist/cad-nauseam.js"
	],
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/cad-nauseam.d.ts",
			"default": "./dist/cad-nauseam.js"
		}
	},
	"main": "./dist/cad-nauseam.js",
	"module": "./dist/cad-nauseam.js",
	"types": "./dist/cad-nauseam.d.ts",
	"files": [
		"dist",
		"src"
	],
	"scripts": {
		"build": "vite build && vite build --config vite.config.site.ts && tsx ./scripts/version.ts > ./site/cad-nauseam/version.json",
		"clean": "shx rm -f pnpm-lock.yaml && git clean -fdX -e !.claude/",
		"dev": "poptab && vite",
		"fix": "ksc fix",
		"init": "mkdir -p .certs && test -f .certs/localhost.pem || mkcert -cert-file .certs/localhost.pem -key-file .certs/localhost-key.pem localhost 127.0.0.1 ::1",
		"lint": "ksc lint",
		"preview": "poptab && vite preview",
		"preview:cloudflare": "poptab && open https://localhost:8787 && wrangler dev --show-interactive-dev-session false --https-cert-path .certs/localhost.pem --https-key-path .certs/localhost-key.pem",
		"release": "bumpp --commit 'Release: %s' && pnpm build && wrangler deploy",
		"test": "vitest run"
	},
	"devDependencies": {
		"@kitschpatrol/shared-config": "^7.5.0",
		"@types/node": "~20.19.39",
		"bumpp": "^11.0.1",
		"happy-dom": "^20.9.0",
		"lit": "^3.3.2",
		"poptab": "^1.1.0",
		"shx": "^0.4.0",
		"tsx": "^4.21.0",
		"typescript": "~5.9.3",
		"vite": "^8.0.9",
		"vitest": "^4.1.5",
		"wrangler": "^4.84.1"
	},
	"peerDependencies": {
		"lit": "^3.0.0"
	},
	"packageManager": "pnpm@10.33.1",
	"devEngines": {
		"runtime": {
			"name": "node",
			"version": ">=22.18.0"
		}
	}
}
